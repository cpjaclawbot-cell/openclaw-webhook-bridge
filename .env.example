# Instance identity (koda or tubez)
INSTANCE_NAME=koda

# Where this API listens
HOST=127.0.0.1
PORT=8091

# Shared secret for inbound Authorization: Bearer <token>
INBOUND_TOKEN=replace-with-long-random-token

# Shared secret used to call peer
OUTBOUND_TOKEN=replace-with-long-random-token

# Peer bridge URL (other instance)
PEER_URL=http://127.0.0.1:8092

# Replay/clock controls
MAX_SKEW_SECONDS=120
NONCE_TTL_SECONDS=600

# Ask/request controls
REQUEST_TIMEOUT_SECONDS=20

# Optional local handler command for inbound requests.
# If set, bridge runs: <LOCAL_HANDLER_CMD> "<text>" and returns stdout as answer.
# Example: LOCAL_HANDLER_CMD=./scripts/handle_request.sh
LOCAL_HANDLER_CMD=

# Optional (for scripts/handle_request_openclaw.sh)
LOCAL_AGENT_ID=main
LOCAL_AGENT_TIMEOUT_SECONDS=45
