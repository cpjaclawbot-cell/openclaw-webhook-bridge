# Instance identity (koda or tubez)
INSTANCE_NAME=koda

# Where this API listens
HOST=127.0.0.1
PORT=8091

# Shared secret for inbound Authorization: Bearer <token>
INBOUND_TOKEN=replace-with-long-random-token

# Shared secret used to call peer
OUTBOUND_TOKEN=replace-with-long-random-token

# Peer bridge URL (other instance)
PEER_URL=http://127.0.0.1:8092

# Replay/clock controls
MAX_SKEW_SECONDS=120
NONCE_TTL_SECONDS=600
